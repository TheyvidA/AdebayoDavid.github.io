      "source": [
        "# Set visualization style\n",
        "sns.set_theme(style=\"whitegrid\")\n",
        "\n",
        "# Loading a sample of the data for computational efficiency in the script\n",
        "url = 'https://gitlab.uwe.ac.uk/da2-adebayo/ml_assignment/-/raw/main/tech_mental_health_burnout.csv'\n",
        "df = pd.read_csv(url).sample(n=20000, random_state=42)\n",
        "\n",
        "# Graph 1: Distribution of Burnout Levels\n",
        "plt.figure(figsize=(8, 5))\n",
        "# FIX: Added hue='burnout_level' and legend=False\n",
        "sns.countplot(data=df, x='burnout_level', order=['Low', 'Moderate', 'High'],\n",
        "              hue='burnout_level', palette='viridis', legend=False)\n",
        "plt.title('Graph 1: Distribution of Burnout Levels in Tech')\n",
        "plt.ylabel('Number of Employees')\n",
        "plt.tight_layout()\n",
        "plt.savefig('graph1_burnout_distribution.png')\n",
        "\n",
        "\n",
        "# Graph 2: Correlation Matrix\n",
        "plt.figure(figsize=(10, 8))\n",
        "cols_of_interest = ['work_hours_per_week', 'job_satisfaction', 'stress_level', 'sleep_hours', 'burnout_score']\n",
        "corr_matrix = df[cols_of_interest].corr()\n",
        "sns.heatmap(corr_matrix, annot=True, cmap='coolwarm', fmt=\".2f\", vmin=-1, vmax=1)\n",
        "plt.title('Graph 2: Correlation Matrix of Key Factors')\n",
        "plt.tight_layout()\n",
        "plt.savefig('graph2_correlation_heatmap.png')\n",
        "\n",
        "\n",
        "# Graph 3: Burnout Score by Job Role\n",
        "plt.figure(figsize=(14, 6))\n",
        "# FIX: Added hue='job_role' and legend=False\n",
        "sns.boxplot(data=df, x='job_role', y='burnout_score',\n",
        "            hue='job_role', palette='Set2', legend=False)\n",
        "plt.xticks(rotation=45, ha='right')\n",
        "plt.title('Graph 3: Burnout Score Distribution by Job Role')\n",
        "plt.tight_layout()\n",
        "plt.savefig('graph3_burnout_by_role.png')\n",
        "\n",
        "# Graph 4: Impact of Sleep on Burnout (Violin Plot)\n",
        "plt.figure(figsize=(10, 6))\n",
        "# FIX: Added hue='burnout_level' and legend=False\n",
        "sns.violinplot(data=df, x='burnout_level', y='sleep_hours', order=['Low', 'Moderate', 'High'],\n",
        "               hue='burnout_level', palette='muted', legend=False)\n",
        "plt.title('Graph 4: The Impact of Sleep on Burnout Severity')\n",
        "plt.tight_layout()\n",
        "plt.savefig('graph4_sleep_impact.png')\n",
        "\n",
        "\n",
        "# Selecting the most predictive features based on EDA\n",
        "features = ['work_hours_per_week', 'job_satisfaction', 'stress_level', 'sleep_hours']\n",
        "X = df[features]\n",
        "y = df['burnout_level']\n",
        "\n",
        "# Encoding the categorical target\n",
        "le = LabelEncoder()\n",
        "y_encoded = le.fit_transform(y) # Encodes alphabetically: High=0, Low=1, Moderate=2\n",
        "\n",
        "# Train/Test Split (80% training, 20% testing)\n",
        "X_train, X_test, y_train, y_test = train_test_split(X, y_encoded, test_size=0.2, random_state=42, stratify=y_encoded)\n",
        "\n",
        "# Feature Scaling (Crucial for Logistic Regression convergence)\n",
        "scaler = StandardScaler()\n",
        "X_train_scaled = scaler.fit_transform(X_train)\n",
        "X_test_scaled = scaler.transform(X_test)\n",
        "\n",
        "\n",
        "# Using 'multinomial' for multi-class classification\n",
        "clf = LogisticRegression(multi_class='multinomial', solver='lbfgs', max_iter=1000, class_weight='balanced')\n",
        "clf.fit(X_train_scaled, y_train)\n",
        "\n",
        "\n",
        "y_pred = clf.predict(X_test_scaled)\n",
        "\n",
        "print(\"--- Model Evaluation ---\")\n",
        "print(\"Overall Accuracy: {:.2f}%\\n\".format(accuracy_score(y_test, y_pred) * 100))\n",
        "print(\"Classification Report:\")\n",
        "print(classification_report(y_test, y_pred, target_names=le.classes_))\n"
      ]
    },
